static const int screenWidth = 800;
static const int screenHeight = 450;

static void GameInit(void);
static void GameLoop(void);
static void GameUpdate(void);
static void GameDraw(void);
static void GameEnd(void);

// INFO: global state from 'global_state.h'
float mouseSensitivity = 1.0f;
Camera3D camera = {0};
float mapWidth = 0.0f;
float mapHeight = 0.0f;
Vector2 mapOffset = {0};
int seed = 0;

int main(void)
{
#if defined(RUN_TESTS)
    printf("Running tests...\n");
    run_tests();
    printf("Tests Complete! :)\n");
    exit(0);
#endif

    GameInit();
#if defined(PLATFORM_WEB)
    emscripten_set_main_loop(GameLoop, 60, 1);
#else
    // SetTargetFPS(60); // Set our game to run at 60 frames-per-second

    // Main game loop
    while (!WindowShouldClose()) // Detect window close button or ESC key
    {
        GameLoop();
    }
#endif
    GameEnd();

    return 0;
}

bool isMapChanged = false;
float mapScale = 0.0f;

Arena scratch;
PathGraph pathGraph;

static void GameInit(void)
{
    // Initialization:
    InitWindow(screenWidth, screenHeight, "Infinity Castle");

    InitAudioDevice(); // Initialize audio device

    mouseSensitivity = 1.0f;

    camera.position = VEC3(0.2, 0.4, 0.2);
    camera.target = VEC3(0.2, 0.4, 0.2);
    camera.up = VEC3(0.0f, 1.0f, 0.0f);
    camera.fovy = 45.0f;
    camera.projection = CAMERA_PERSPECTIVE;

    mapWidth = screenHeight;
    mapHeight = screenHeight;
    mapOffset = VEC2(0, 0);
    seed = 100;

    mapScale = 0.5f;

    scratch = arena_init(10 << 20);
    pathGraph = generateOrganicPaths(&scratch, VEC2(screenWidth / 2.0, screenHeight / 2.0));
}

// Update and draw game frame
static void GameLoop(void)
{
    GameUpdate();
    GameDraw();
}

static void GameUpdate(void)
{
    float dt = GetFrameTime();
    float offsetChange = 1.0f;
    if (isMapChanged)
    {
        isMapChanged = false;
    }
    UpdateCamera(&camera, CAMERA_FREE);

    if (IsKeyDown(KEY_EQUAL))
    {
        mapScale += 0.01f;
        isMapChanged = true;
    }

    if (IsKeyDown(KEY_MINUS))
    {

        mapScale -= 0.01f;
        isMapChanged = true;
    }

    if (IsKeyDown(KEY_L))
    {
        isMapChanged = true;
        mapOffset.x += offsetChange * dt;
    }

    if (IsKeyDown(KEY_H))
    {
        isMapChanged = true;
        mapOffset.x -= offsetChange * dt;
    }

    if (IsKeyDown(KEY_J))
    {
        isMapChanged = true;
        mapOffset.y -= offsetChange * dt;
    }

    if (IsKeyDown(KEY_K))
    {
        isMapChanged = true;
        mapOffset.y += offsetChange * dt;
    }
}

static void GameDraw(void)
{
    BeginDrawing();
    {
        ClearBackground(RAYWHITE);
        DrawPathNodes(&pathGraph);
        BeginMode3D(camera);
        {
        }
        EndMode3D();
    }
#ifndef NDEBUG
    DrawFPS(10, 10);
#endif /* ifndef NDEBUG */
    EndDrawing();
}

static void GameEnd(void)
{
  
    // De-Initialization:
    CloseAudioDevice();
    CloseWindow();
}
